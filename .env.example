# ===== Course defaults (works out-of-the-box) =====
DOMAIN_ID=science

# LLM: recommended defaults for the course
# auto  -> try local Ollama if available, else g4f if installed, else mock
LLM_PROVIDER=auto
LLM_MODEL=auto
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings: hash is always available; sentence-transformers is higher quality
EMBED_PROVIDER=sentence-transformers
EMBED_MODEL=BAAI/bge-m3
HASH_EMBED_DIM=384

# OCR / document structure
OCR_BACKEND=auto
PADDLEOCR_LANG=ru

# Graph backends
GRAPH_BACKEND=dual  # dual|neo4j|memgraph|none
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please_change_me
MEMGRAPH_URI=bolt://localhost:7688
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# Qdrant: hybrid dense+sparse retrieval by default
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_RETRIEVAL_MODE=hybrid
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_SPARSE_DIM=2048

# External services
GROBID_URL=http://localhost:8070

# Polite API usage (recommended for OpenAlex/Crossref/NCBI)
CONTACT_EMAIL=
USER_AGENT=

# Demo store (retrieval few-shot)
DEMO_ENABLED=true

# Agentic mode for hypothesis generation
HYP_AGENT_ENABLED=true
HYP_AGENT_BACKEND=internal  # internal|smolagents
HYP_AGENT_MAX_STEPS=4

# smolagents settings (only used when HYP_AGENT_BACKEND=smolagents)
SMOL_MODEL_BACKEND=scireason  # scireason|g4f|transformers
SMOL_MODEL_ID=HuggingFaceTB/SmolLM2-1.7B-Instruct
SMOL_MAX_NEW_TOKENS=768
SMOL_DEVICE_MAP=
SMOL_TORCH_DTYPE=
SMOL_G4F_MODEL=auto
SMOL_EXECUTOR=local  # local|docker
SMOL_PRINT_STEPS=false

# Multimodal verification / Qwen2.5-VL
VLM_BACKEND=none  # none|qwen2_vl|g4f
VLM_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
VLM_MAX_NEW_TOKENS=512
VLM_STRUCTURED_OUTPUT=true

# Optional GNN mode (PyTorch Geometric) for candidate hypotheses
HYP_GNN_ENABLED=false
HYP_GNN_EPOCHS=80
HYP_GNN_HIDDEN_DIM=64
HYP_GNN_LR=0.01
HYP_GNN_NODE_CAP=300

# Temporal link prediction / TGNN
HYP_TGNN_ENABLED=true
HYP_TGNN_BACKEND=auto  # auto|pyg|heuristic
HYP_TGNN_RECENT_WINDOW_YEARS=3
HYP_TGNN_HALF_LIFE_YEARS=2.0
HYP_TGNN_MIN_CANDIDATE_SCORE=0.05
HYP_TGNN_MEMORY_DIM=64
HYP_TGNN_TIME_DIM=16
HYP_TGNN_EPOCHS=25
