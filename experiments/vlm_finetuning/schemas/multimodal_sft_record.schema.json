{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MultimodalSFTRecord",
  "type": "object",
  "required": [
    "id",
    "messages"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "task_type": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "content": {}
        }
      }
    },
    "metadata": {
      "type": "object"
    },
    "task_family": {
      "type": "string"
    },
    "artifact_version": {
      "type": [
        "integer",
        "string"
      ]
    },
    "step_context": {
      "type": "object"
    },
    "edge_annotations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "geography": {
      "type": "object"
    },
    "science_branches": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "image": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "required": [
        "id"
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "task_type"
          ]
        },
        {
          "required": [
            "task_family"
          ]
        }
      ]
    }
  ]
}